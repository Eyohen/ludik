{
  "routes": [
    {
      "route": "/",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      }
    },
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "no-cache, max-age=0, must-revalidate"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
