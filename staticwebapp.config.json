{
  "globalHeaders": {
    "Cache-Control": "no-store, max-age=0, must-revalidate"
  },
  "routes": [
    {
      "route": "/",
      "headers": {
        "Cache-Control": "no-store, max-age=0, must-revalidate"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store, max-age=0, must-revalidate"
      }
    },
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.{css,js,png,jpg,jpeg,webp,gif,svg,ico,woff,woff2,json,txt}"
    ]
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
